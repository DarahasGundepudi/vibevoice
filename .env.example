# ─── VibeVoice AI Audio Engine Configuration ─────────────────────────────────
# Copy this file to .env and fill in your keys.

# Server
HOST=0.0.0.0
PORT=8000

# Gemini API Key (required for Podcast + Interviewer endpoints)
GEMINI_API_KEY=your-gemini-api-key-here

# HuggingFace Token (optional — only for gated/private models)
HF_TOKEN=

# Device: "cuda" for GPU, "cpu" for CPU (very slow)
DEVICE=cuda

# Default voice preset for TTS
DEFAULT_VOICE=Carter (US Male)

# Podcast output directory (inside container or local)
PODCAST_OUTPUT_DIR=/tmp/vibevoice_podcasts

# Offline mode (set to 1 after models are cached to skip HF connectivity checks)
TRANSFORMERS_OFFLINE=0
HF_HUB_OFFLINE=0
